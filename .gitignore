# Dependencies
node_modules/
web/node_modules/
vendor/

# Env files
.env
.env.*
!.env.example
web/.env.local
web/.env*.local

# Laravel — generated/runtime files under api/
# (The leading `api/` matters: previous patterns were anchored to repo
# root, so they never matched and we ended up tracking compiled views,
# the laravel.log, and bootstrap/cache/{packages,services}.php — the
# last of which kept resetting to a STALE provider list on every
# `git pull`, crashing prod with `Laravel\Sentinel\SentinelServiceProvider
# not found`. Don't move these patterns back to root-anchored.)
api/storage/*.key
api/storage/logs/*.log
api/storage/framework/cache/data/*
api/storage/framework/sessions/*
api/storage/framework/testing/*
api/storage/framework/views/*.php
api/bootstrap/cache/*.php

# Next.js
.next/
web/.next/
out/
web/out/

# Build/cache
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-store/
.DS_Store
Thumbs.db

# TypeScript
*.tsbuildinfo
web/tsconfig.tsbuildinfo
# Local Claude Code state — worktrees + personal settings stay ignored.
# .claude/skills/ is shared with the team and DOES get committed (project-
# scoped skills like .claude/skills/template-creator). Pattern uses
# .claude/* + targeted negation so we keep traversal but ignore everything
# in the directory except skills/ — re-including a single subdir requires
# the parent NOT be wholesale-ignored, hence the trailing * (not /).
.claude/*
!.claude/skills/

# Local-only scratchpad for one-shot scripts (e.g. tenant seed scripts
# piped to prod via SSH, manifest validators, ad-hoc tinker bodies).
# These are utilities — they run on prod once and don't belong in git,
# but we keep them on disk for reference + iteration.
tmp/
