APP_NAME=BookReady
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=UTC
AUTH_COOKIE_TRUSTED_ORIGINS=http://localhost:3000,https://localhost:3000,http://app.daysbookings.site,https://app.daysbookings.site,https://app.bkrdy.me
AUTH_COOKIE_DOMAIN=

# Domain used to build tenant subdomains (e.g. {slug}.bookready.test)
APP_DOMAIN=bookready.test

# Comma-separated list of central/landlord domains (not tenants)
CENTRAL_DOMAINS=bookready.app,bookready.test,localhost,127.0.0.1

# Database (central / landlord)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=bookready_central
DB_USERNAME=root
DB_PASSWORD=

# Tenant databases share the same MySQL instance, prefixed with "tenant_"
TENANCY_DB_PREFIX=tenant_

# Cache & Sessions
CACHE_STORE=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
QUEUE_CONNECTION=redis

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_CLIENT=predis

# Stripe / Cashier
STRIPE_KEY=pk_test_
STRIPE_SECRET=sk_test_
STRIPE_WEBHOOK_SECRET=whsec_
CASHIER_CURRENCY=usd
CASHIER_CURRENCY_LOCALE=en

# Resend (email)
RESEND_API_KEY=
MAIL_MAILER=resend
MAIL_FROM_ADDRESS=notifications@mybookready.com
MAIL_FROM_NAME="BookReady"

# Google OAuth (sign-in / sign-up)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://api.bkrdy.me/api/v1/auth/google/callback

# Storage
FILESYSTEM_DISK=local
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

LOG_CHANNEL=stack
LOG_LEVEL=debug
BROADCAST_CONNECTION=log
